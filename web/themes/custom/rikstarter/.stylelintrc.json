{
  "ignoreFiles": ["dist/**", "node_modules/**"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "apply",
          "reference",
          "source",
          "tailwind",
          "theme",
          "utility",
          "variant",
          "custom-variant",
          "screen",
          "custom-media"
        ]
      }
    ],
    "media-query-no-invalid": null,
    "media-feature-name-no-unknown": null
  }
}

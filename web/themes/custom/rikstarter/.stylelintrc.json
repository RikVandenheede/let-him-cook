{
  "ignoreFiles": ["dist/**", "node_modules/**"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "apply",
          "reference",
          "source",
          "tailwind",
          "theme",
          "utility",
          "variant",
          "custom-variant",
          "screen"
        ]
      }
    ]
  }
}
